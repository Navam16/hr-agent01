# ╔══════════════════════════════════════════════════════════════════╗
# ║              HR VOICE AGENT — ENVIRONMENT VARIABLES              ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your key below
#   3. NEVER commit your .env file to GitHub (it's in .gitignore)
#
# ════════════════════════════════════════════════════════════════════
#
# SERVICE: Groq
# USED FOR: LLM inference (llama-3.3-70b) + Whisper speech-to-text
# GET KEY: https://console.groq.com  →  Sign up free  →  API Keys
# FREE TIER: 14,400 requests/day — more than enough for demos
# ════════════════════════════════════════════════════════════════════
GROQ_API_KEY=gsk_your_groq_api_key_here

# ════════════════════════════════════════════════════════════════════
# THAT'S IT. Only 1 API key needed for the full MVP.
#
# Services that need NO API key:
#   gTTS (text-to-speech)  → uses Google TTS, free, no key
#   PyPDF2 (PDF parsing)   → runs locally, no key
#   Streamlit              → runs locally, no key
# ════════════════════════════════════════════════════════════════════
